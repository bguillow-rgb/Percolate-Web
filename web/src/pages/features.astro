---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import { SITE } from '../consts';
---
<BaseLayout
  title="Features"
  description="A closer look at Percolate: coffee shelf, structured cupping log, label scan, flavor quiz, what-to-brew picks, taste profile, and community ratings."
  path="/features"
>
  <Fragment slot="head">
    <BreadcrumbSchema crumbs={[{ name: 'Features', url: `${SITE.url}/features` }]} />
  </Fragment>

  <span class="eyebrow" style="text-align:center;display:block;">{SITE.name}</span>
  <h1>Features</h1>
  <p class="effective">Everything Percolate does, in one place.</p>

  <!-- Pick / What to brew -->
  <section class="feature-row">
    <div class="feature-row-copy">
      <span class="eyebrow">The Pick</span>
      <h3>What should I brew today?</h3>
      <p>Tell Percolate what you&rsquo;re in the mood for, bright and fruity, rich and chocolatey, an easy daily cup, and it suggests a coffee from the bags you already own, matched on roast, origin, process, and flavor.</p>
      <p>Discovery is fine, but the everyday question is &ldquo;what do I brew right now?&rdquo;, and the answer should come from your shelf, not a shopping cart.</p>
    </div>
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/06-pick-tonight.png"
        alt="Percolate pick screen suggesting a coffee from the user's shelf based on their taste"
        loading="eager"
        width="260"
      />
    </div>
  </section>

  <!-- Shelf -->
  <section class="feature-row feature-row--reverse">
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/04-shelf.png"
        alt="Shelf screen showing coffee bags by status, owned, wishlist, finished"
        loading="lazy"
        width="260"
      />
    </div>
    <div class="feature-row-copy">
      <span class="eyebrow">Shelf</span>
      <h3>Your coffee, perfectly organized</h3>
      <p>Every bag in one place. Track each coffee by roaster, origin, and status, <strong>owned</strong>, <strong>wishlist</strong>, or <strong>finished</strong>. Roast level, process, and elevation are kept per bag so the shelf reads like a cupping table.</p>
      <p>Filter by origin, process, or roast. Sort by what you&rsquo;ve brewed least recently, so the back of the shelf gets its turn before the beans go stale.</p>
    </div>
  </section>

  <!-- Flavor Quiz / Taste Profile -->
  <section class="feature-row">
    <div class="feature-row-copy">
      <span class="eyebrow">Taste Profile</span>
      <h3>A flavor quiz that learns</h3>
      <p>Answer a few questions about how you like your coffee, roast, acidity, body, and the flavors you reach for, and Percolate starts matching you to beans you&rsquo;ll actually enjoy.</p>
      <p>Your palate sharpens with every cupping note you log. Built from your real shelf and your real cups, not from a single five-question quiz.</p>
    </div>
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/03-taste-quiz.png"
        alt="Flavor quiz interface asking the user about roast, acidity, and flavor preferences"
        loading="lazy"
        width="260"
      />
    </div>
  </section>

  <!-- Browse / Discover -->
  <section class="feature-row feature-row--reverse">
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/01-home.png"
        alt="Percolate home screen showing a personal pick and roasters to browse"
        loading="lazy"
        width="260"
      />
    </div>
    <div class="feature-row-copy">
      <span class="eyebrow">Browse</span>
      <h3>Find your next bag</h3>
      <p>Browse single origins, blends, and espresso roasts by roaster, origin, process, or flavor. Curated by how the coffee actually tastes, not by what a store wants to move this week.</p>
      <p>Every coffee links out to its roaster so you can buy when you&rsquo;re ready. No shopping pressure, no algorithmic push, just a well-organized catalog with affiliate disclosure on the page.</p>
    </div>
  </section>

  <!-- Bean Detail + Label Scan -->
  <section class="feature-row">
    <div class="feature-row-copy">
      <span class="eyebrow">Bean Detail &amp; Scan</span>
      <h3>Every coffee, scanned and remembered</h3>
      <p>Point your camera at a bag and Percolate reads the label to pull the roaster, origin, process, and roast, no typing out a long washed Ethiopian by hand. Tap any coffee to see its full profile, community rating, and your own cupping history.</p>
      <p>When you&rsquo;re ready to buy, &ldquo;Buy from&rdquo; links connect you directly to the roaster, with affiliate disclosure right on the page.</p>
    </div>
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/02-bean-detail.png"
        alt="Bean detail page showing a coffee's origin, process, roast, tasting notes, and community rating"
        loading="lazy"
        width="260"
      />
    </div>
  </section>

  <!-- My Palate / Year in Coffee -->
  <section class="feature-row feature-row--reverse">
    <div class="feature-row-shot">
      <img
        src="/assets/screenshots/05-my-palate.png"
        alt="My Palate screen showing the user's taste profile across roast, acidity, body, and favorite origins"
        loading="lazy"
        width="260"
      />
    </div>
    <div class="feature-row-copy">
      <span class="eyebrow">My Palate</span>
      <h3>See your taste take shape</h3>
      <p>Every cup you log feeds <strong>My Palate</strong>, your profile across roast, acidity, body, and the origins and processes you keep coming back to. The washed Colombians you reach for daily and the natural you rated once both reveal themselves.</p>
      <p>At year-end, a <strong>Year in Coffee</strong> recap sums up your top roasters, origins, total cups, and the most-brewed bag of the year. Sharable as an image card.</p>
    </div>
  </section>

  <section class="cta-section">
    <h2 class="section-title" style="margin-top:0;">Ready when you are</h2>
    <p class="cta-body">
      Percolate lands on the App Store soon. Questions or feedback?
      Email <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>.
    </p>
    <div class="cta-row">
      {SITE.appStoreUrl ? (
        <a class="btn" href={SITE.appStoreUrl}>Download on iOS</a>
      ) : (
        <span class="btn btn--disabled">App Store (Coming Soon)</span>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>
