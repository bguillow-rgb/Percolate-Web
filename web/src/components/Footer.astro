---
import { SITE, FOOTER_NAV } from '../consts';
const year = new Date().getFullYear();
---
<hr class="footer-rule" />
<nav class="footer-nav" aria-label="Footer navigation">
  {FOOTER_NAV.map((item) => (
    <a href={item.href}>{item.label}</a>
  ))}
</nav>
<p class="footer">
  Percolate is a free, independent app. We do not roast or sell coffee.
  &ldquo;Buy from&rdquo; links to roasters and specialty retailers may earn us
  a small commission at no cost to you.
</p>
<p class="footer">
  Questions? <a href={`mailto:${SITE.supportEmail}`} style="color:inherit;border-bottom:none;">{SITE.supportEmail}</a>
</p>
<p class="footer">&copy; {year} {SITE.name}, a {SITE.legalEntity} product. All rights reserved.</p>
